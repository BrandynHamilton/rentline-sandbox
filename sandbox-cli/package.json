{
  "name": "rentline-sandbox",
  "version": "0.1.0",
  "description": "CLI and MCP server for the Rentline Sandbox real estate simulation game",
  "type": "module",
  "bin": {
    "sandbox": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [

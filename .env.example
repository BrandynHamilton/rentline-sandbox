# =============================================================================
# Rentline Sandbox — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Both sandbox-api/ and sandbox-web/ load from this file automatically.
#
# sandbox-api: loaded via python-dotenv from sandbox-api/app/core/config.py
#              (resolves to repo root: ../../../.env)
# sandbox-web: copy to sandbox-web/.env.local (Next.js convention)
#              or set NEXT_PUBLIC_* vars directly in Vercel project settings.
# =============================================================================


# =============================================================================
# APP
# =============================================================================

VERSION=0.1.0


# =============================================================================
# SANDBOX API SERVER
# =============================================================================

HOST=0.0.0.0
PORT=6532

# Database
# Defaults to SQLite (fine for local dev). Use PostgreSQL for staging/production.
# DATABASE_URL=sqlite:///./data/sandbox.db
# DATABASE_URL=postgresql://user:password@localhost:5432/rentline_sandbox


# =============================================================================
# CLERK AUTH
# Same Clerk application as Rentline — users sign in once, both apps work.
# Get values from: https://dashboard.clerk.com → API Keys
# =============================================================================

CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-domain>.clerk.accounts.dev

# Frontend (safe to expose — used by sandbox-web)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...


# =============================================================================
# SUPABASE
# Can be the same project as Rentline (sandbox tables are fully isolated)
# or a dedicated sandbox Supabase project.
# Get values from: https://supabase.com → Project Settings → API Keys
# =============================================================================

SUPABASE_URL=https://<your-project-ref>.supabase.co

# Backend privileged key — bypasses RLS, NEVER expose to frontend
SUPABASE_PRIVATE_KEY=sb_secret_...
# Legacy fallback (still works):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt


# =============================================================================
# SANDBOX WEB (Next.js)
# These NEXT_PUBLIC_* vars must also be set in sandbox-web/.env.local
# or in Vercel project settings for the sandbox-web deployment.
# =============================================================================

# Sandbox API base URL
# Local dev:   http://localhost:6532
# Production:  https://sandbox-api.rentline.xyz  (or same host, different port)
NEXT_PUBLIC_SANDBOX_API_URL=http://localhost:6532


# =============================================================================
# SECURITY
# =============================================================================

# Admin key — required for POST /api/sandbox/properties/sync and mint-tusdc
ADMIN_API_KEY=your-sandbox-admin-secret

# Optional additional static API keys (comma-separated)
# API_KEYS=key1,key2

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://sandbox.rentline.xyz

# Rate limiting
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60


# =============================================================================
# SANDBOX GAME DEFAULTS
# These are the defaults used when creating a new game room.
# All can be overridden per-game via the POST /api/sandbox/games body.
# =============================================================================

# Starting tUSDC balance per player (default: $100,000)
# SANDBOX_STARTING_BALANCE_USDC=100000

# Max players per game room (default: 8)
# SANDBOX_MAX_PLAYERS=8

# Default max turns per game (default: 12 = 12 months)
# SANDBOX_DEFAULT_MAX_TURNS=12


# =============================================================================
# RWA-ISSUER-SIM
# Optional — enables the POST /api/sandbox/properties/sync endpoint and live
# AVM re-fetching during MARKET_MOVE phase. Leave blank to disable.
# =============================================================================

# RWA_ISSUER_URL=http://localhost:8000


# =============================================================================
# RENTLINE BACKEND BRIDGE
# Optional — when set, simulated rent payments write real ledger entries into
# the landlord's Rentline dashboard (purely cosmetic for demos).
# Leave both blank to disable. The sandbox works fully without this.
# =============================================================================

# RENTLINE_API_URL=https://api.rentline.xyz
# RENTLINE_SANDBOX_BRIDGE_KEY=your-bridge-api-key


# =============================================================================
# ON-CHAIN — ARBITRUM SEPOLIA  (Phase 1)
# Admin wallet for minting MockUSDC and calling SandboxDistributor.
# Required only when on-chain token features are active.
# =============================================================================

# ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# ARBITRUM_SEPOLIA_CHAIN_ID=421614
# SANDBOX_ADMIN_PRIVATE_KEY=0x...


# =============================================================================
# ON-CHAIN — DEDICATED ORBIT CHAIN  (Phase 2)
# Set these after deploying your Arbitrum Orbit chain.
# See SANDBOX_PLAN.md → Part 6 for deployment steps.
# =============================================================================

# ORBIT_RPC_URL=https://sandbox-rpc.rentline.xyz
# ORBIT_CHAIN_ID=<your-orbit-chain-id>
# ORBIT_MOCK_USDC_ADDRESS=0x...
# ORBIT_DISTRIBUTOR_ADDRESS=0x...

# RWA Issuer Sim — Environment Variables
# Copy to .env and fill in your values.

# =============================================================================
# APP
# =============================================================================
DEBUG=false
API_PREFIX=/api/v1

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./rwa_issuer.db

# =============================================================================
# METADATA / ORACLE
# =============================================================================
METADATA_DIR=./metadata
TOKEN_URI_BASE=http://localhost:8000/metadata/

# =============================================================================
# AVALANCHE
# =============================================================================
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
AVALANCHE_PRIVATE_KEY=your-deployer-private-key

# =============================================================================
# FACTORY CONTRACT ADDRESSES
# Set after running: forge script script/DeployFactories.s.sol --broadcast
# Admin path (backend) calls factory.createFor(); user path calls factory.create()
# =============================================================================
PROPERTY_TOKEN_FACTORY_ADDRESS=
CRE_FACTORY_ADDRESS=
NFT_TOKEN_FACTORY_ADDRESS=
SECURITY_TOKEN_FACTORY_ADDRESS=   # legacy — kept for standalone SecurityToken deploys

# =============================================================================
# SCRAPING (x402 → Heurist Firecrawl)
# =============================================================================
X402_PRIVATE_KEY=your-evm-private-key

# =============================================================================
# AVM INTEGRATIONS (optional)
# =============================================================================
ZILLOW_API_KEY=
ZILLOW_API_HOST=zillow-com1.p.rapidapi.com
ATTOM_API_KEY=
ATTOM_API_BASE=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# =============================================================================
# RENTLINE API
# =============================================================================
RENTLINE_URL=http://localhost:6531
RENTLINE_ADMIN_API_KEY=your-admin-key

# =============================================================================
# AUTH
# =============================================================================
ADMIN_API_KEY=your-admin-api-key

# =============================================================================
# APP
# =============================================================================
DEBUG=false
API_PREFIX=/api/v1

# =============================================================================
# DATABASE
# SQLite for dev (default). Switch to postgres:// for prod.
# =============================================================================
DATABASE_URL=sqlite:///./rwa_issuer.db

# =============================================================================
# METADATA / ORACLE
# METADATA_DIR: where {geoId}.json files are written
# TOKEN_URI_BASE: base URL for tokenURI — must resolve to /metadata/
# =============================================================================
METADATA_DIR=./metadata
TOKEN_URI_BASE=http://localhost:8000/metadata/

# =============================================================================
# AVALANCHE
# =============================================================================
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
AVALANCHE_PRIVATE_KEY=your-deployer-private-key

# =============================================================================
# CONTRACT VERIFICATION (Snowtrace / Snowscan)
# Get a free key from: https://snowscan.xyz/myapikey
# Used by backend/scripts/deploy_tokens.py after each deployment.
# Leave blank to skip verification.
# =============================================================================
ETHERSCAN_API_KEY=your-snowscan-api-key

# =============================================================================
# SCRAPING (x402 → Heurist Firecrawl)
# EVM private key for x402 micropayments. The wallet must be funded
# on the network accepted by the Heurist Firecrawl endpoint.
# =============================================================================
X402_PRIVATE_KEY=your-evm-private-key

# =============================================================================
# AVM INTEGRATIONS (all optional — omit to disable that source)
# =============================================================================

# Zillow Bridge API via RapidAPI
# Get key from: https://rapidapi.com/apimaker/api/zillow-com1
ZILLOW_API_KEY=your-rapidapi-key
ZILLOW_API_HOST=zillow-com1.p.rapidapi.com

# ATTOM Property API
# Get key from: https://api.gateway.attomdata.com
ATTOM_API_KEY=your-attom-api-key
ATTOM_API_BASE=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# =============================================================================
# RENTLINE API
# Used by POST /tokens/{geo_id}/push_rentline to register token addresses
# =============================================================================
RENTLINE_URL=http://localhost:6531
RENTLINE_ADMIN_API_KEY=your-admin-key

# =============================================================================
# AUTH — protects POST /tokens/{geo_id}/deploy/* endpoints
# Backend reads ADMIN_API_KEY; clients send it as X-Admin-Key header.
# Frontend reads NEXT_PUBLIC_ADMIN_API_KEY and sends it automatically.
# =============================================================================
ADMIN_API_KEY=your-admin-api-key
NEXT_PUBLIC_ADMIN_API_KEY=your-admin-api-key
